[includeIf "gitdir:/Users/jyxc-dz-0100170/codespace/"]
    path = ~/.gitconfig-company

[includeIf "gitdir:/Users/jyxc-dz-0100170/workspace/"]
    path = ~/.gitconfig-company

[user]
    useConfigOnly = true

[core]
    editor = vim
    excludesfile = ~/.gitignore_global
	pager = delta

[init]
    defaultBranch = main

[color]
    ui = auto

[column]
    ui = auto

[help]
    autocorrect = prompt

[fetch]
    prune = true

[pull]
    rebase = false

[push]
    autoSetupRemote = true

[rebase]
    autoStash = true

[rerere]
    enabled = true

[merge]
	# Per-machine override in ~/.gitconfig.local — older git (< 2.35)
	# rejects unknown styles at parse time, so leave the default unset here.

[diff]
    algorithm = histogram

[tag]
    sort = version:refname

[alias]
    st = status -sb
    sw = switch
    co = checkout
    br = branch
    ci = commit
    amend = commit --amend
    last = log -1 --stat
    lg = log --graph --decorate --date=short --pretty=format:'%C(yellow)%h%Creset %Cgreen%ad%Creset %C(cyan)%an%Creset %C(auto)%d%Creset %s'
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Monokai Extended
	plus-style = "syntax #003800"
	minus-style = "syntax #3f0001"
	file-style = bold yellow
	hunk-header-style = syntax bold

# Machine-local overrides win — keep this include last.
[include]
    path = ~/.gitconfig.local
