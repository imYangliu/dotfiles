# Shared SSH defaults.
#
# Host-specific entries should live in ~/.ssh/config.local so they stay out of
# the shared dotfiles repo. OpenSSH uses the first value it sees, so keep the
# include before the generic Host * block.

Include ~/.ssh/config.local

Host git-ssh.linu.me
  ProxyCommand cloudflared access ssh --hostname %h

Host *
  ServerAliveInterval 30
  ServerAliveCountMax 3
  TCPKeepAlive yes
  HashKnownHosts yes
  UpdateHostKeys yes
  ControlMaster auto
  ControlPersist 10m
  ControlPath ~/.ssh/cm-%C
