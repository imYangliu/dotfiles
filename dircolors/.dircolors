.gz 01;38;5;9
.iso 01;38;5;9
.jar 01;38;5;9
.lz 01;38;5;9
.lz4 01;38;5;9
.lzma 01;38;5;9
.nar 01;38;5;9
.pkg 01;38;5;9
.rar 01;38;5;9
.rpm 01;38;5;9
.tar 01;38;5;9
.tgz 01;38;5;9
.txz 01;38;5;9
.whl 01;38;5;9
.xz 01;38;5;9
.zip 01;38;5;9
.zst 01;38;5;9

