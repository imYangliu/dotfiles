# Ghostty-inspired dircolors configuration.
#
# This palette maps common ls(1) categories onto Ghostty 1.2.3's built-in
# "Ghostty Default Style Dark" ANSI colors so directory listings fit the
# terminal's default look instead of the stock GNU palette.
#
# Reference palette:
#   8  -> #666666   bright black
#   9  -> #d54e53   bright red
#   10 -> #b9ca4b   bright green
#   11 -> #e7c547   bright yellow
#   12 -> #7aa6da   bright blue
#   13 -> #c397d8   bright magenta
#   14 -> #70c0b1   bright cyan
#   15 -> #eaeaea   bright white

COLORTERM ?*
TERM ghostty*
TERM xterm-ghostty
TERM tmux*
TERM screen*
TERM xterm*
TERM *color*

RESET 0
DIR 01;38;5;12
LINK 01;38;5;14
MULTIHARDLINK 38;5;8
FIFO 38;5;11;48;5;0
SOCK 01;38;5;13
DOOR 01;38;5;13
BLK 01;38;5;11;48;5;0
CHR 01;38;5;11;48;5;0
ORPHAN 01;38;5;9
MISSING 01;38;5;9
SETUID 38;5;15;48;5;9
SETGID 38;5;0;48;5;11
CAPABILITY 01;38;5;13
STICKY_OTHER_WRITABLE 38;5;0;48;5;10
OTHER_WRITABLE 38;5;12;48;5;10
STICKY 38;5;15;48;5;12
EXEC 01;38;5;10

# Archives and packages
.7z 01;38;5;9
.apk 01;38;5;9
.bz 01;38;5;9
.bz2 01;38;5;9
.cab 01;38;5;9
